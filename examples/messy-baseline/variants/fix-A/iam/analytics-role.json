{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LakeFull",
      "Effect": "Allow",
      "Action": "s3:*",
      "Resource": "arn:aws:s3:::pipeline-lake/*"
    },
    {
      "Sid": "Warehouse",
      "Effect": "Allow",
      "Action": ["dynamodb:GetItem", "dynamodb:Query", "dynamodb:BatchGetItem"],
      "Resource": "arn:aws:dynamodb:us-east-1:111122223333:table/analytics-events"
    },
    {
      "Sid": "Secrets",
      "Effect": "Allow",
      "Action": "secretsmanager:GetSecretValue",
      "Resource": "*"
    },
    {
      "Sid": "Keys",
      "Effect": "Allow",
      "Action": "kms:Decrypt",
      "Resource": "*"
    }
  ]
}
