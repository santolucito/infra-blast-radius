{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LakeFull",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": "arn:aws:s3:::pipeline-lake/*"
    },
    {
      "Sid": "LakeExtra",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:ListBucket", "s3:DeleteObject", "s3:PutBucketPolicy"],
      "Resource": "arn:aws:s3:::pipeline-lake/*"
    },
    {
      "Sid": "Warehouse",
      "Effect": "Allow",
      "Action": "dynamodb:*",
      "Resource": "arn:aws:dynamodb:us-east-1:111122223333:table/analytics-*"
    },
    {
      "Sid": "Secrets",
      "Effect": "Allow",
      "Action": "secretsmanager:GetSecretValue",
      "Resource": "arn:aws:secretsmanager:us-east-1:111122223333:secret:analytics/warehouse-AbCdEf"
    },
    {
      "Sid": "Keys",
      "Effect": "Allow",
      "Action": "kms:Decrypt",
      "Resource": "*"
    }
  ]
}
