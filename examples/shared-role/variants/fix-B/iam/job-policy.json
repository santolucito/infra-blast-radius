{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SharedPlatformAccess",
      "Effect": "Allow",
      "Action": [
        "s3:*",
        "secretsmanager:GetSecretValue",
        "dynamodb:*",
        "sqs:SendMessage",
        "sqs:ReceiveMessage",
        "kms:Decrypt"
      ],
      "Resource": "*"
    }
  ]
}
